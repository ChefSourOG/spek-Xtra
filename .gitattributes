# Force LF line endings for files that must remain Unix-style,
# even when the repository is checked out on Windows.
*.sh    text eol=lf
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.m4    text eol=lf
*.ac    text eol=lf
*.am    text eol=lf

# Let Git handle line endings for everything else automatically.
*       text=auto
